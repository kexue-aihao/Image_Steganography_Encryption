<Window x:Class="PictureEncryptionApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="图片隐写加密工作台"
        Icon="Assets/AppIcon.ico"
        Height="900"
        Width="1260"
        MinHeight="760"
        MinWidth="1080"
        Background="#FFF5F7FB">
    <Window.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#FFD8E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Foreground" Value="#FF1F2937" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,6" />
            <Setter Property="Foreground" Value="#FF334155" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="96" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="图片隐写加密工作台"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#FF0F172A" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="#FF475569"
                       Text="Windows 10 / 11 桌面工具，支持 AES-GCM 加密、自适应图片门禁与高对抗隐写。" />
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="嵌入加密">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,16,0">
                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="载体图片" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="图片文件" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="EmbedCarrierPathTextBox"
                                                 Margin="0,0,10,0"
                                                 IsReadOnly="True"
                                                 VerticalContentAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Content="浏览..."
                                                Click="BrowseEmbedCarrierButton_Click" />
                                    </Grid>
                                    <TextBlock x:Name="EmbedCapacityTextBlock"
                                               Margin="0,10,0,0"
                                               TextWrapping="Wrap"
                                               Foreground="#FF475569"
                                               Text="尚未选择载体图片。" />
                                    <TextBlock x:Name="EmbedSupportTextBlock"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               FontWeight="SemiBold"
                                               Foreground="#FF0F766E"
                                               Text="适配性门禁正在等待图片输入。" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="适配性评估" />
                                    <TextBox x:Name="EmbedAssessmentTextBox"
                                             Height="150"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             AcceptsReturn="True" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="秘密载荷" />

                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton x:Name="EmbedTextRadioButton"
                                                     Content="文本"
                                                     GroupName="PayloadType"
                                                     IsChecked="True"
                                                     Checked="EmbedModeToggle_Checked" />
                                        <RadioButton x:Name="EmbedFileRadioButton"
                                                     Margin="18,0,0,0"
                                                     Content="文件"
                                                     GroupName="PayloadType"
                                                     Checked="EmbedModeToggle_Checked" />
                                    </StackPanel>

                                    <StackPanel x:Name="EmbedTextPanel">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="文本内容" />
                                        <TextBox x:Name="EmbedSecretTextBox"
                                                 Height="180"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 AcceptsReturn="True"
                                                 TextChanged="EmbedInputChanged" />
                                    </StackPanel>

                                    <StackPanel x:Name="EmbedFilePanel" Visibility="Collapsed">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="秘密文件" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="EmbedSecretFilePathTextBox"
                                                     Margin="0,0,10,0"
                                                     IsReadOnly="True"
                                                     VerticalContentAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Content="浏览..."
                                                    Click="BrowseEmbedSecretFileButton_Click" />
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="安全设置" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="密码" />
                                    <PasswordBox x:Name="EmbedPasswordBox" PasswordChanged="EmbedInputChanged" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="确认密码" />
                                    <PasswordBox x:Name="EmbedConfirmPasswordBox" PasswordChanged="EmbedInputChanged" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="输出文件" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="PNG 输出路径" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="EmbedOutputPathTextBox"
                                                 Margin="0,0,10,0"
                                                 IsReadOnly="True"
                                                 VerticalContentAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Content="另存为..."
                                                Click="BrowseEmbedOutputButton_Click" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                        <Button x:Name="EmbedActionButton"
                                                Content="加密并嵌入"
                                                Click="EmbedActionButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1.2*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Text="图片预览" />
                                <Border BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="4" Background="#FFF8FAFC">
                                    <Viewbox StretchDirection="DownOnly">
                                        <Image x:Name="EmbedPreviewImage"
                                               Stretch="Uniform"
                                               Width="340"
                                               Height="340" />
                                    </Viewbox>
                                </Border>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="运行日志" />
                                <TextBox x:Name="EmbedStatusTextBox"
                                         Height="230"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         AcceptsReturn="True" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="提取解密">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,16,0">
                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="隐写图片" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="图片文件" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ExtractImagePathTextBox"
                                                 Margin="0,0,10,0"
                                                 IsReadOnly="True"
                                                 VerticalContentAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Content="浏览..."
                                                Click="BrowseExtractImageButton_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="解密设置" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="密码" />
                                    <PasswordBox x:Name="ExtractPasswordBox" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="提取文件保存目录" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ExtractOutputFolderTextBox"
                                                 Margin="0,0,10,0"
                                                 IsReadOnly="True"
                                                 VerticalContentAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Content="浏览..."
                                                Click="BrowseExtractFolderButton_Click" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                        <Button x:Name="ExtractActionButton"
                                                Content="提取并解密"
                                                Click="ExtractActionButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="提取结果" />
                                    <TextBlock x:Name="ExtractMetadataTextBlock"
                                               Foreground="#FF475569"
                                               Text="尚未开始提取。" />
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="恢复文本 / 结果日志" />
                                    <TextBox x:Name="ExtractResultTextBox"
                                             Height="260"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             AcceptsReturn="True" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Column="1" Style="{StaticResource SectionBorderStyle}" Margin="0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Text="图片预览" />
                            <Border BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="4" Background="#FFF8FAFC">
                                <Viewbox StretchDirection="DownOnly">
                                    <Image x:Name="ExtractPreviewImage"
                                           Stretch="Uniform"
                                           Width="340"
                                           Height="340" />
                                </Viewbox>
                            </Border>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
